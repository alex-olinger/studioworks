# =============================================================================
# .claudeignore — StudioWorks Monorepo
# Next.js + TypeScript + Turbo + Postgres + Docker + Kubernetes
# =============================================================================

# -----------------------------------------------------------------------------
# Node / Package Management
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml

# Lock files (large, never useful to read)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# -----------------------------------------------------------------------------
# Turbo
# -----------------------------------------------------------------------------
.turbo/
**/.turbo/

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
**/.next/
out/
**/out/

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
dist/
**/dist/
build/
**/build/
.output/
**/.output/

# Minified / compiled assets
*.min.js
*.min.css
*.map

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
**/*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Don't ignore Dockerfiles or compose files — those are worth reading.
# Ignore generated/runtime Docker artifacts:
.docker/volumes/
docker-volumes/

# -----------------------------------------------------------------------------
# Kubernetes
# -----------------------------------------------------------------------------
# Keep manifests readable; ignore generated/rendered output:
**/rendered-manifests/
**/helm-output/
**/.helm/cache/
**/.helm/repository/

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sql.bak
**/migrations/generated/
**/pgdata/
postgres-data/
pg_data/

# -----------------------------------------------------------------------------
# Test Output
# -----------------------------------------------------------------------------
coverage/
**/coverage/
.nyc_output/
test-results/
playwright-report/
**/__snapshots__/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.cert
secrets/

# -----------------------------------------------------------------------------
# Editor & OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# Caches
# -----------------------------------------------------------------------------
.cache/
**/.cache/
.eslintcache
.stylelintcache
.parcelcache/

# -----------------------------------------------------------------------------
# CI / Artifacts
# -----------------------------------------------------------------------------
.github/workflows/   # Keep readable — remove this line if you want CI visible
artifacts/
**/artifacts/
