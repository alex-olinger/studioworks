# Build outputs
.next/
dist/
build/
*.js.map

# Compiled JS artifacts (source is TypeScript — compiled outputs are not committed).
# src/ trees hold only .ts/.tsx; package roots hold in-place tsc output (e.g. job-spec.js).
# App-root config .js (next.config.js, postcss.config.js, tailwind.config.js) is intentionally NOT ignored.
**/src/**/*.js
packages/*/*.js
vitest.workspace.js

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Environment variables
.env
.env.local
.env.development
.env.production

# Prisma
prisma/dev.db

# OS files
.DS_Store
Thumbs.db
*.Identifier

