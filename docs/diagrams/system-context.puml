@startuml system-context
title StudioWorks — System Context

left to right direction

skinparam backgroundColor white
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam defaultFontSize 11
skinparam nodesep 60
skinparam ranksep 80

skinparam actor {
  BackgroundColor #1168bd
  BorderColor #08427b
  FontColor white
  FontSize 12
}

skinparam rectangle {
  BackgroundColor #dae8fc
  BorderColor #6c8ebf
  FontSize 12
  RoundCorner 8
}

actor "Freelancer\n//[Person]//" as user

rectangle "StudioWorks Platform\n//[Software System]//" as sw

rectangle "Email Client\n//[External — future]//" as email #f5f5f5
rectangle "AWS S3\n//[External — future]//" as s3 #f5f5f5

user --> sw : manages clients,\nprojects & billing
sw ..> email : sends invoice\nnotifications [future]
sw ..> s3 : stores generated\nfiles [future]

@enduml
