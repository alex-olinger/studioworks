@startuml frontend-routing
title StudioWorks — Frontend Page Routing (Next.js App Router)

left to right direction

skinparam backgroundColor white
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam defaultFontSize 11
skinparam ArrowFontBackground white
skinparam ArrowColor #444444
skinparam ArrowThickness 1.5
skinparam nodesep 30
skinparam ranksep 50

skinparam component {
  BackgroundColor #dae8fc
  BorderColor #6c8ebf
  FontSize 11
}

skinparam rectangle {
  BackgroundColor #f5f5f5
  BorderColor #999999
  FontSize 12
  RoundCorner 6
}

rectangle "App Shell — layout.tsx\n(nav + root layout)" as shell {

  component "Dashboard\n**/**\n--\nSummary stats" as dashboard

  component "Client List\n**/clients**\n--\nAll clients" as clients

  component "New Client\n**/clients/new**\n--\nCreate form" as clientNew

  component "Client Detail\n**/clients/:id**\n--\nClient + projects" as clientDetail

  component "Project List\n**/projects**\n--\nAll projects" as projects

  component "Project Detail\n**/projects/:id**\n--\nEntries + invoices\nGenerate invoice" as projectDetail

  component "Time Entries\n**/projects/:id/time**\n--\nLog time" as time

  component "Expenses\n**/projects/:id/expenses**\n--\nLog expenses" as expenses

  component "Invoice List\n**/invoices**\n--\nAll invoices" as invoices

  component "Invoice Detail\n**/invoices/:id**\n--\nStatus + PDF download\nJob polling" as invoiceDetail

}

' Primary navigation from dashboard
dashboard --> clients       : <back:white>nav</back>
dashboard --> projects      : <back:white>nav</back>
dashboard --> invoices      : <back:white>nav</back>

' Client pages
clients --> clientNew       : <back:white>new client</back>
clients --> clientDetail    : <back:white>view</back>

' Project pages — entered from the project list
projects --> projectDetail       : <back:white>view</back>

projectDetail --> time           : <back:white>time entries</back>
projectDetail --> expenses       : <back:white>expenses</back>
projectDetail --> invoiceDetail  : <back:white>generate invoice</back>

' Invoice pages
invoices --> invoiceDetail : <back:white>view</back>

@enduml
