@startuml api-routes
title StudioWorks — API Route Handlers

left to right direction

skinparam backgroundColor white
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam defaultFontSize 11
skinparam classAttributeIconSize 0
skinparam ArrowFontBackground white
skinparam ArrowColor #444444
skinparam ArrowThickness 1.5
skinparam nodesep 50
skinparam ranksep 60

skinparam class {
  BackgroundColor #dae8fc
  BorderColor #6c8ebf
}

skinparam class<<schema>> {
  BackgroundColor #e8f5e9
  BorderColor #66bb6a
}

skinparam class<<dependency>> {
  BackgroundColor #f3e5f5
  BorderColor #ab47bc
}

skinparam class<<PrismaClient singleton>> {
  BackgroundColor #f3e5f5
  BorderColor #ab47bc
}

' ── External dependencies ───────────────────────────────────────────────────

class db <<PrismaClient singleton>> {
  +client : Delegate<Client>
  +project : Delegate<Project>
  +timeEntry : Delegate<TimeEntry>
  +expense : Delegate<Expense>
  +invoice : Delegate<Invoice>
  +job : Delegate<Job>
  +$transaction()
}

class queue <<dependency>> {
  +add(name, data): Job
}

' ── Zod schemas ─────────────────────────────────────────────────────────────

class CreateClientSchema <<schema>> {
  +name : string [min 1]
  +email? : string [email]
  +address? : string
  +notes? : string
}

class UpdateClientSchema <<schema>> {
  ' partial() of CreateClientSchema
  +name? : string [min 1]
  +email? : string [email]
  +address? : string
  +notes? : string
}

class CreateProjectSchema <<schema>> {
  +name : string [min 1]
  +hourlyRate? : number [positive]
}

class UpdateProjectSchema <<schema>> {
  +name? : string [min 1]
  +status? : enum [ACTIVE|COMPLETED|ARCHIVED]
  +hourlyRate? : number [positive]
}

class CreateTimeEntrySchema <<schema>> {
  +description : string [min 1]
  +date : datetime | date
  +hours : number [positive]
  +billable : boolean [default true]
}

class CreateExpenseSchema <<schema>> {
  +description : string [min 1]
  +date : datetime | date
  +amount : number [positive]
  +category? : string
  +billable : boolean [default true]
}

class UpdateInvoiceSchema <<schema>> {
  +status? : enum [DRAFT|SENT|PAID|OVERDUE]
  +dueDate? : datetime
  +notes? : string
}

' ── Route handlers ───────────────────────────────────────────────────────────

class clientRoutes <<FastifyPlugin>> {
  +POST /clients()
  +GET /clients()
  +GET /clients/:id()
  +PATCH /clients/:id()
}

class projectRoutes <<FastifyPlugin>> {
  +POST /clients/:clientId/projects()
  +GET /clients/:clientId/projects()
  +GET /projects/:id()
  +PATCH /projects/:id()
}

class timeEntryRoutes <<FastifyPlugin>> {
  +POST /projects/:projectId/time-entries()
  +GET /projects/:projectId/time-entries()
  +DELETE /time-entries/:id()
}

class expenseRoutes <<FastifyPlugin>> {
  +POST /projects/:projectId/expenses()
  +GET /projects/:projectId/expenses()
  +DELETE /expenses/:id()
}

class invoiceRoutes <<FastifyPlugin>> {
  +POST /projects/:projectId/invoices()
  +GET /invoices()
  +GET /invoices/:id()
  +PATCH /invoices/:id()
  +GET /invoices/:id/pdf()
}

class jobRoutes <<FastifyPlugin>> {
  +GET /jobs/:id()
}

class buildApp <<Factory>> {
  +buildApp() : FastifyInstance
}

' ── Relationships ────────────────────────────────────────────────────────────

' buildApp registers all route plugins
buildApp ..> clientRoutes    : <back:white>registers</back>
buildApp ..> projectRoutes   : <back:white>registers</back>
buildApp ..> timeEntryRoutes : <back:white>registers</back>
buildApp ..> expenseRoutes   : <back:white>registers</back>
buildApp ..> invoiceRoutes   : <back:white>registers</back>
buildApp ..> jobRoutes       : <back:white>registers</back>

' Schema usage
clientRoutes    ..> CreateClientSchema  : <back:white>validates with</back>
clientRoutes    ..> UpdateClientSchema  : <back:white>validates with</back>
projectRoutes   ..> CreateProjectSchema : <back:white>validates with</back>
projectRoutes   ..> UpdateProjectSchema : <back:white>validates with</back>
timeEntryRoutes ..> CreateTimeEntrySchema : <back:white>validates with</back>
expenseRoutes   ..> CreateExpenseSchema   : <back:white>validates with</back>
invoiceRoutes   ..> UpdateInvoiceSchema   : <back:white>validates with</back>

' DB dependency
clientRoutes    ..> db : <back:white><<use>></back>
projectRoutes   ..> db : <back:white><<use>></back>
timeEntryRoutes ..> db : <back:white><<use>></back>
expenseRoutes   ..> db : <back:white><<use>></back>
invoiceRoutes   ..> db : <back:white><<use>></back>
jobRoutes       ..> db : <back:white><<use>></back>

' Queue dependency — only invoices enqueue jobs
invoiceRoutes ..> queue : <back:white>enqueues PDF job</back>

' Schema grouping
together {
  class CreateClientSchema
  class UpdateClientSchema
}

together {
  class CreateProjectSchema
  class UpdateProjectSchema
}

together {
  class CreateTimeEntrySchema
  class CreateExpenseSchema
  class UpdateInvoiceSchema
}

together {
  class clientRoutes
  class projectRoutes
  class timeEntryRoutes
  class expenseRoutes
  class invoiceRoutes
  class jobRoutes
}

@enduml
